        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"vibecheck\"}[1m])",
          "legendFormat": "commits/s"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"vibecheck\"}[1m])",
          "legendFormat": "rollbacks/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
